{
  "name": "typescript-hello",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hello World with Typescript using Vite and Tailwind CSS",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "menu": "tsx src/cli.ts menu",
    "console": "tsx src/main.ts",
    "seat-map": "tsx src/cli.ts seat-map",
    "count-seats": "tsx src/cli.ts count-seats",
    "check-seats": "tsx src/cli.ts check-seats",
    "find-adjacent": "tsx src/cli.ts find-adjacent",
    "check-seat": "tsx src/cli.ts check-seat",
    "reserve": "tsx src/cli.ts reserve",
    "unreserve": "tsx src/cli.ts unreserve",
    "reset-seats": "tsx src/cli.ts reset-seats",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^22.15.16",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "tsx": "^4.19.2",
    "vite": "^5.4.0"
  }
}
